# Repository env-vars reference. Copy to `.env` and fill in.

# ---- Data paths (read by Submission.__init__) ----
ALPHASIGHT_CORPUS_DIR=/abs/path/to/dataset/corpus
ALPHASIGHT_PRICES_DIR=/abs/path/to/dataset/prices
ALPHASIGHT_PRICES_MINUTE_DIR=/abs/path/to/dataset/prices_minute
ALPHASIGHT_CATALOG_PATH=/abs/path/to/dataset/catalog.jsonl

# Writable dir for run output + caches / intermediates.
ALPHASIGHT_OUTPUT_DIR=./output

# ---- Inference LLM ----
# OpenAI-compatible endpoint (vLLM / Ollama / OpenAI / etc.).
ALPHASIGHT_LLM_BASE_URL=http://localhost:8000/v1
ALPHASIGHT_LLM_MODEL=Qwen2.5-72B-Instruct

# Only needed for endpoints that actually require auth (e.g. hosted OpenAI).
# Local vLLM ignores the key, so this can stay unset.
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1

# ---- Embedding model (Qwen3-VL-Embedding-8B) — all OPTIONAL ----
# The dense path is an augmentation; if none of this resolves the system
# runs BM25-only. Preferred: serve the embedding model with vLLM and
# point these at its OpenAI-compatible /v1/embeddings endpoint (avoids
# in-process VL loading + GPU contention with the inference LLM).
# ALPHASIGHT_EMBED_BASE_URL=http://localhost:8001/v1
# ALPHASIGHT_EMBED_MODEL_NAME=Qwen3-VL-Embedding-8B
#
# Fallback: in-process load from a local model dir (sentence-transformers
# or transformers AutoModel). Default path below; override if needed.
# ALPHASIGHT_EMBED_MODEL=/root/.cache/modelscope/hub/models/Qwen/Qwen3-VL-Embedding-8B
