# Local config — gitignored. Do not commit.

# ---- Data paths ----
ALPHASIGHT_CORPUS_DIR=./dataset/corpus
ALPHASIGHT_PRICES_DIR=./dataset/prices
ALPHASIGHT_PRICES_MINUTE_DIR=./dataset/prices_minute
ALPHASIGHT_CATALOG_PATH=./dataset/catalog.jsonl
ALPHASIGHT_OUTPUT_DIR=./output

# ---- Inference LLM (apicz resource-pooled gateway) ----
ALPHASIGHT_LLM_BASE_URL=https://apicz.boyuerichdata.com/v1
ALPHASIGHT_LLM_MODEL=gpt-4.1
OPENAI_API_KEY=sk-Pmis7gCC2ZiQqf7B3jUHGnKVq0rM2z1VvUGxaLBJibijMezv

# Resource-pooled endpoint: sporadic 429/5xx -> retry (provider requirement)
ALPHASIGHT_LLM_RETRIES=6
ALPHASIGHT_LLM_RETRY_INTERVAL=30

# ---- Embedding via the same gateway (enables dense retrieval) ----
ALPHASIGHT_EMBED_BASE_URL=https://apicz.boyuerichdata.com/v1
ALPHASIGHT_EMBED_MODEL_NAME=text-embedding-3-large

# ---- Eval harness judge model ----
ALPHASIGHT_EVAL_MODEL=gpt-4.1
