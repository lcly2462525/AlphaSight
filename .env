# Tracked config (private repo). Cloud eval reads this.

# ---- Data paths ----
ALPHASIGHT_CORPUS_DIR=./dataset/corpus
ALPHASIGHT_PRICES_DIR=./dataset/prices
ALPHASIGHT_PRICES_MINUTE_DIR=./dataset/prices_minute
ALPHASIGHT_CATALOG_PATH=./dataset/catalog.jsonl
ALPHASIGHT_OUTPUT_DIR=./output

# ---- Pipeline LLM = LOCAL vLLM (started by vllm.sh on :8000) ----
# generate/review run against the local served model; the cloud box
# has no guaranteed outbound internet, so an external gateway here
# hangs the whole run. Keep this pointed at localhost.
ALPHASIGHT_LLM_BASE_URL=http://localhost:8000/v1
ALPHASIGHT_LLM_MODEL=Qwen3-235B-A22B-Instruct-2507
OPENAI_API_KEY=sk-none
# Per-request hard timeout (s) so a dead endpoint fails fast, not hangs.
ALPHASIGHT_LLM_TIMEOUT=120
ALPHASIGHT_LLM_RETRIES=3
ALPHASIGHT_LLM_RETRY_INTERVAL=15



# ---- Dense retrieval: disabled (no local embedding server) ----
# BM25-only. To enable, point these at a reachable embeddings endpoint.
export ALPHASIGHT_EMBED_BASE_URL=http://127.0.0.1:8002/v1
export ALPHASIGHT_EMBED_MODEL_NAME=harrier-oss-v1-0.6b

# ---- Eval judge = SEPARATE apicz gateway (tools/eval_review.py) ----
# Scoring is offline and decoupled from the pipeline; it may use the
# external gateway from a box that does have internet.
ALPHASIGHT_EVAL_BASE_URL=https://apicz.boyuerichdata.com/v1
ALPHASIGHT_EVAL_API_KEY=sk-Pmis7gCC2ZiQqf7B3jUHGnKVq0rM2z1VvUGxaLBJibijMezv
ALPHASIGHT_EVAL_MODEL=gpt-4.1
